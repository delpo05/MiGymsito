<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_white"
    android:orientation="vertical"
    android:padding="20dp"
    android:layout_margin="16dp">

    <TextView
        android:id="@+id/tv_titulo_detalle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Detalle: Sentadillas"
        android:textColor="@color/negro"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:stretchColumns="*">

        <TableRow android:background="#EEEEEE" android:padding="8dp">
            <TextView android:text="Serie" android:textStyle="bold" android:textColor="@color/negro" android:gravity="center"/>
            <TextView android:id="@+id/tv_label_ant" android:textStyle="bold" android:textColor="@color/negro" android:gravity="center"/>
            <TextView android:id="@+id/tv_label_post"  android:textStyle="bold" android:textColor="@color/negro" android:gravity="center"/>
            <TextView android:text="Dif." android:textStyle="bold" android:textColor="@color/negro" android:gravity="center"/>
        </TableRow>

        <!-- Contenedor dinámico para las filas -->
        <LinearLayout
            android:id="@+id/ll_filas_detalle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </TableLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#CCCCCC"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/btn_cerrar_detalle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cerrar"
            android:textAllCaps="false"
            android:backgroundTint="#403C3C"
            android:textColor="@color/blanco"
            app:cornerRadius="20dp"/>
    </LinearLayout>

</LinearLayout>