<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/negro"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <include layout="@layout/header" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="30dp"
                    android:text="Mi Progreso"
                    android:textColor="@color/blanco"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <!-- Selector Rutinas -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/menu_desplegable_rutinas_layout"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="30dp"
                    android:layout_marginEnd="30dp"
                    android:layout_marginBottom="16dp"
                    android:hint="Seleccionar Rutina"
                    app:boxStrokeColor="@color/blanco"
                    app:hintTextColor="@color/blanco"
                    android:textColorHint="@color/gris_pista"
                    app:endIconTint="@color/blanco">

                    <AutoCompleteTextView
                        android:id="@+id/autoCompleteRutinas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:padding="12dp"
                        android:textSize="14sp"
                        android:popupBackground="#1A1A1A"
                        android:textColor="@color/blanco" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Selector Secciones -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/menu_desplegable_secciones_layout"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="30dp"
                    android:layout_marginEnd="30dp"
                    android:layout_marginBottom="16dp"
                    android:hint="Filtrar por sección"
                    app:boxStrokeColor="@color/blanco"
                    app:hintTextColor="@color/blanco"
                    android:textColorHint="@color/gris_pista"
                    app:endIconTint="@color/blanco">

                    <AutoCompleteTextView
                        android:id="@+id/autoCompleteSecciones"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:padding="12dp"
                        android:textSize="14sp"
                        android:popupBackground="#1A1A1A"
                        android:textColor="@color/blanco" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Selector Ejercicios -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/menu_desplegable_ejercicios_layout"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="30dp"
                    android:layout_marginEnd="30dp"
                    android:layout_marginBottom="16dp"
                    android:hint="Seleccionar Ejercicio"
                    app:boxStrokeColor="@color/blanco"
                    app:hintTextColor="@color/blanco"
                    android:textColorHint="@color/gris_pista"
                    app:endIconTint="@color/blanco">

                    <AutoCompleteTextView
                        android:id="@+id/autoCompleteEjercicios"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:padding="12dp"
                        android:textSize="14sp"
                        android:popupBackground="#1A1A1A"
                        android:textColor="@color/blanco" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Selector Tipo Consulta -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/menu_desplegable_consulta_layout"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="30dp"
                    android:layout_marginEnd="30dp"
                    android:layout_marginBottom="32dp"
                    android:hint="Tipo de estadistica"
                    app:boxStrokeColor="@color/blanco"
                    app:hintTextColor="@color/blanco"
                    android:textColorHint="@color/gris_pista"
                    app:endIconTint="@color/blanco">

                    <AutoCompleteTextView
                        android:id="@+id/autoCompleteConsulta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:padding="12dp"
                        android:popupBackground="#1A1A1A"
                        android:textColor="@color/blanco"
                        android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConsultarProgreso"
                    android:layout_width="200dp"
                    android:layout_height="50dp"
                    android:text="Consultar"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/blanco"
                    android:backgroundTint="#403C3C"
                    app:cornerRadius="25dp" />

                <!-- Gráfico de Barras -->
                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/barChart"
                    android:layout_width="match_parent"
                    android:layout_height="350dp"
                    android:layout_marginTop="30dp"
                    android:layout_marginBottom="20dp" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/negro"
        app:headerLayout="@layout/header_menu_desplegable"
        app:menu="@menu/popup_header"
        app:itemTextColor="@color/blanco"
        app:itemIconTint="@color/blanco" />

</androidx.drawerlayout.widget.DrawerLayout>
