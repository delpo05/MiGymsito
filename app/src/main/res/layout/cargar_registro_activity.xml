<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/negro"
    android:fitsSystemWindows="true"
    tools:context=".CargarRegistroActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <include layout="@layout/header" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/tvNombreEjercicio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Nombre del Ejercicio"
                android:textColor="@color/blanco"
                android:textSize="24sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/llInputs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:padding="8dp"
                app:layout_constraintTop_toBottomOf="@id/tvNombreEjercicio">

                <TextView
                    android:id="@+id/labelSerie"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Serie"
                    android:textColor="@color/blanco"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toStartOf="@+id/labelReps"
                    app:layout_constraintHorizontal_weight="0.8"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/labelReps"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Repeticiones"
                    android:textColor="@color/blanco"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toStartOf="@+id/tvPesoLabel"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintStart_toEndOf="@+id/labelSerie"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvPesoLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Peso (kg)"
                    android:textColor="@color/blanco"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_weight="1.2"
                    app:layout_constraintStart_toEndOf="@+id/labelReps"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvSerieValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textColor="@color/blanco"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@+id/npRepeticiones"
                    app:layout_constraintEnd_toEndOf="@+id/labelSerie"
                    app:layout_constraintStart_toStartOf="@+id/labelSerie"
                    app:layout_constraintTop_toTopOf="@+id/npRepeticiones" />

                <NumberPicker
                    android:id="@+id/npRepeticiones"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:theme="@style/PickerStyle"
                    app:layout_constraintEnd_toEndOf="@+id/labelReps"
                    app:layout_constraintStart_toStartOf="@+id/labelReps"
                    app:layout_constraintTop_toBottomOf="@+id/labelReps" />

                <LinearLayout
                    android:id="@+id/containerPeso"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:layout_constraintBottom_toBottomOf="@+id/npRepeticiones"
                    app:layout_constraintEnd_toEndOf="@+id/tvPesoLabel"
                    app:layout_constraintStart_toStartOf="@+id/tvPesoLabel"
                    app:layout_constraintTop_toTopOf="@+id/npRepeticiones">

                    <NumberPicker
                        android:id="@+id/npPesoEntero"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:theme="@style/PickerStyle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text=","
                        android:textColor="@color/blanco"
                        android:textSize="24sp" />

                    <NumberPicker
                        android:id="@+id/npPesoDecimal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:theme="@style/PickerStyle" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <Button
                android:id="@+id/btnCargar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="#403C3C"
                android:text="Cargar"
                android:textAllCaps="false"
                android:textColor="@color/blanco"
                app:cornerRadius="25dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/llInputs" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/clTimerContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:padding="8dp"
                app:layout_constraintTop_toBottomOf="@id/btnCargar">

                <TextView
                    android:id="@+id/tvTimerTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DESCANSAR"
                    android:textColor="#808080"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cvTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:cardBackgroundColor="#1A1A1A"
                    app:cardElevation="8dp"
                    app:cardMaxElevation="10dp"
                    app:cardUseCompatPadding="true"
                    app:strokeColor="#40FFFFFF"
                    app:strokeWidth="0.5dp"
                    app:cardCornerRadius="12dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvTimerTitle">

                    <TextView
                        android:id="@+id/tvTimerValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="4dp"
                        android:text="01:00"
                        android:textColor="@color/blanco"
                        android:textSize="32sp"
                        android:textStyle="bold" />
                </com.google.android.material.card.MaterialCardView>

                <ImageView
                    android:id="@+id/ivEditTimer"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/ic_edit_outline"
                    android:clickable="true"
                    android:focusable="true"
                    app:layout_constraintBottom_toBottomOf="@+id/cvTimer"
                    app:layout_constraintStart_toEndOf="@+id/cvTimer"
                    app:layout_constraintTop_toTopOf="@+id/cvTimer"
                    app:tint="@color/blanco" />

                <ImageButton
                    android:id="@+id/btnStartTimer"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_media_play"
                    app:layout_constraintBottom_toBottomOf="@+id/cvTimer"
                    app:layout_constraintEnd_toStartOf="@+id/cvTimer"
                    app:layout_constraintTop_toTopOf="@+id/cvTimer"
                    app:tint="@color/blanco" />

                <ImageButton
                    android:id="@+id/btnResetTimer"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_rotate"
                    app:layout_constraintBottom_toBottomOf="@+id/cvTimer"
                    app:layout_constraintStart_toEndOf="@+id/ivEditTimer"
                    app:layout_constraintTop_toTopOf="@+id/cvTimer"
                    app:tint="@color/blanco" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <FrameLayout
                android:id="@+id/flHistorialHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="#1A1A1A"
                app:layout_constraintTop_toBottomOf="@id/clTimerContainer">

                <TextView
                    android:id="@+id/tvHistorialHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="8dp"
                    android:text="Historial"
                    android:textColor="@color/blanco"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btnEliminarUltimo"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_delete"
                    app:tint="@color/blanco" />
            </FrameLayout>

            <TableLayout
                android:id="@+id/tlHistorial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stretchColumns="*"
                app:layout_constraintTop_toBottomOf="@id/flHistorialHeader">

                <TableRow
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#0F0F0F">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:padding="8dp"
                        android:text="Series"
                        android:textColor="@color/blanco"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:padding="8dp"
                        android:text="Repeticiones"
                        android:textColor="@color/blanco"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvColumnaPeso"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:padding="8dp"
                        android:text="Peso"
                        android:textColor="@color/blanco"
                        android:textStyle="bold" />
                </TableRow>
            </TableLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvHistorial"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tlHistorial" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/negro"
        app:headerLayout="@layout/header_menu_desplegable"
        app:menu="@menu/popup_header"
        app:itemTextColor="@color/blanco"
        app:itemIconTint="@color/blanco" />

</androidx.drawerlayout.widget.DrawerLayout>
