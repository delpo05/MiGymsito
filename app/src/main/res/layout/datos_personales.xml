<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/negro"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <include layout="@layout/header" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Saludo -->
                <TextView
                    android:id="@+id/tvHolaNombre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hola, nombre"
                    android:textColor="@color/blanco"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="2dp" />

                <!-- Título de la Página -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Configuración de Perfil"
                    android:textColor="@color/gris_pista"
                    android:textSize="12sp"
                    android:layout_marginBottom="16dp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />

                <!-- CARD DATOS PERSONALES -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="#0F0F0F"
                    app:cardCornerRadius="15dp"
                    app:strokeColor="#383636"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_person"
                                app:tint="@color/blanco" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Datos de cuenta"
                                android:textColor="@color/blanco"
                                android:textStyle="bold"
                                android:textSize="16sp"
                                android:layout_marginStart="10dp" />
                        </LinearLayout>

                        <!-- 1. Nombre -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            app:boxStrokeColor="@color/blanco"
                            app:hintTextColor="@color/blanco"
                            android:textColorHint="@color/gris_pista"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etDatoNombre"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Nombre completo"
                                android:textColor="@color/blanco"
                                android:textStyle="bold" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- 2. Correo -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            app:boxStrokeColor="@color/blanco"
                            app:hintTextColor="@color/blanco"
                            android:textColorHint="@color/gris_pista"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etDatoCorreo"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Correo Electrónico"
                                android:textColor="@color/blanco"
                                android:textStyle="bold" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- 4. Fecha y Género -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.8"
                                android:layout_marginEnd="4dp"
                                app:boxStrokeColor="@color/blanco"
                                app:hintTextColor="@color/blanco"
                                android:textColorHint="@color/gris_pista"
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etDatoFecha"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="Nacimiento"
                                    android:textColor="@color/blanco"
                                    android:textStyle="bold"
                                    android:focusable="false"
                                    android:clickable="true" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1.2"
                                android:layout_marginStart="4dp"
                                app:boxStrokeColor="@color/blanco"
                                app:hintTextColor="@color/blanco"
                                android:textColorHint="@color/gris_pista"
                                app:endIconTint="@color/blanco"
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
                                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                                    android:id="@+id/etDatoGenero"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="Género"
                                    android:inputType="none"
                                    android:textColor="@color/blanco"
                                    android:textStyle="bold"
                                    android:popupBackground="@color/negro" /> <!-- ARREGLO PARA QUITAR LÍNEAS BLANCAS -->
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- CARD DATOS FISICOS -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:cardBackgroundColor="#0F0F0F"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="#383636"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/baseline_fitness_center"
                                app:tint="@color/blanco" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Físico actual"
                                android:textColor="@color/blanco"
                                android:textStyle="bold"
                                android:textSize="16sp"
                                android:layout_marginStart="10dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginEnd="6dp"
                                app:boxStrokeColor="@color/blanco"
                                app:hintTextColor="@color/blanco"
                                android:textColorHint="@color/gris_pista"
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etDatoAltura"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="Altura (cm)"
                                    android:textColor="@color/blanco"
                                    android:textStyle="bold"
                                    android:inputType="numberDecimal" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="6dp"
                                app:boxStrokeColor="@color/blanco"
                                app:hintTextColor="@color/blanco"
                                android:textColorHint="@color/gris_pista"
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etDatoPeso"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="Peso (kg)"
                                    android:textColor="@color/blanco"
                                    android:textStyle="bold"
                                    android:inputType="numberDecimal" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- BOTON -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGuardarDatos"
                    android:layout_width="220dp"
                    android:layout_height="50dp"
                    android:layout_gravity="center_horizontal"
                    android:text="Actualizar datos"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:onClick="EventoBotonActualizar"
                    android:textColor="@color/blanco"
                    app:cornerRadius="25dp"
                    android:backgroundTint="#403C3C" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/negro"
        app:headerLayout="@layout/header_menu_desplegable"
        app:menu="@menu/popup_header"
        app:itemTextColor="@color/blanco"
        app:itemIconTint="@color/blanco" />

</androidx.drawerlayout.widget.DrawerLayout>
