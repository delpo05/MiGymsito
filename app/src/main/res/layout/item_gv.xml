<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp">

    <RelativeLayout
        android:id="@+id/container_item"
        android:layout_width="match_parent"
        android:layout_height="170dp"
        android:background="@drawable/card_border_white"
        android:padding="10dp">

        <!-- Opciones (tres puntos) - Área de toque aumentada pero alineado a la esquina -->
        <TextView
            android:id="@+id/tv_opciones"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:gravity="top|end"
            android:text="⋮"
            android:textColor="@color/blanco"
            android:textSize="24sp"
            android:textStyle="bold"
            android:visibility="gone"
            android:elevation="2dp"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <!-- Nombre del Item -->
        <TextView
            android:id="@+id/tv_nombre_item"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:gravity="center"
            android:layout_marginEnd="40dp"
            android:layout_marginStart="40dp"
            android:text="Nombre"
            android:textColor="@color/blanco"
            android:textStyle="bold"
            android:textSize="16sp"
            android:visibility="gone" />

        <!-- Imagen del Ejercicio -->
        <ImageView
            android:id="@+id/iv_item_imagen"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/tv_nombre_item"
            android:layout_marginTop="5dp"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <!-- Botón + para añadir -->
        <ImageView
            android:id="@+id/btn_item_add"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_centerInParent="true"
            android:background="@drawable/bg_circle_white"
            android:backgroundTint="@color/blanco"
            android:src="@drawable/ic_add"
            android:padding="15dp"
            app:tint="@color/negro"
            android:visibility="visible"
            android:clickable="false"
            android:focusable="false" />

    </RelativeLayout>
</FrameLayout>