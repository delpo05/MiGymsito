<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/negro"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/main_registro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingBottom="60dp">

        <!-- Aumentamos el espacio superior para bajar todo el contenido -->
        <View
            android:layout_width="match_parent"
            android:layout_height="80dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:text="REGISTRO"
            android:textColor="@color/blanco"
            android:textSize="28sp"
            android:textStyle="bold" />

        <!-- CARD PARA AGRUPAR EL FORMULARIO -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="30dp"
            android:layout_marginRight="30dp"
            android:layout_marginBottom="32dp"
            app:cardBackgroundColor="#111111"
            app:cardCornerRadius="16dp"
            app:strokeColor="#1F1F1F"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp">

                <!-- Nombre -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:hint="Nombre completo"
                    app:boxStrokeColor="@color/blanco"
                    app:hintTextColor="@color/blanco"
                    android:textColorHint="#999999">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etRegNombre"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:textColor="@color/blanco"
                        android:textStyle="bold" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Correo -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:hint="Correo electrónico"
                    app:boxStrokeColor="@color/blanco"
                    app:hintTextColor="@color/blanco"
                    android:textColorHint="#999999">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etRegCorreo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:textColor="@color/blanco"
                        android:textStyle="bold" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Contraseña -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:hint="Contraseña"
                    app:boxStrokeColor="@color/blanco"
                    app:hintTextColor="@color/blanco"
                    android:textColorHint="#999999"
                    app:passwordToggleEnabled="true"
                    app:passwordToggleTint="@color/blanco">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etRegContrasenia"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:textColor="@color/blanco"
                        android:textStyle="bold" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Fecha y Género -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:hint="Nacimiento"
                        app:boxStrokeColor="@color/blanco"
                        app:hintTextColor="@color/blanco"
                        android:textColorHint="#999999">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etRegFechaNac"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:focusable="false"
                            android:clickable="true"
                            android:textColor="@color/blanco"
                            android:textStyle="bold" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Género"
                        app:boxStrokeColor="@color/blanco"
                        app:hintTextColor="@color/blanco"
                        android:textColorHint="#999999"
                        app:endIconTint="@color/blanco">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/etRegGenero"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:textColor="@color/blanco"
                            android:textStyle="bold" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Peso y Altura -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:hint="Peso (kg)"
                        app:boxStrokeColor="@color/blanco"
                        app:hintTextColor="@color/blanco"
                        android:textColorHint="#999999">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etRegPeso"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textColor="@color/blanco"
                            android:textStyle="bold" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Altura (cm)"
                        app:boxStrokeColor="@color/blanco"
                        app:hintTextColor="@color/blanco"
                        android:textColorHint="#999999">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etRegAltura"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textColor="@color/blanco"
                            android:textStyle="bold" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Botón REGISTRAR -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegistrar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginLeft="40dp"
            android:layout_marginRight="40dp"
            android:layout_marginBottom="40dp"
            android:onClick="EventoBotonRegistrar"
            android:text="REGISTRAR"
            android:textColor="@color/negro"
            android:textSize="18sp"
            android:textStyle="bold"
            app:backgroundTint="@color/blanco"
            app:cornerRadius="30dp" />

        <!-- Botón VOLVER -->
        <ImageButton
            android:id="@+id/btnVolver"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@android:color/transparent"
            android:onClick="EventoBotonVolver"
            android:src="@drawable/ic_back_arrow"
            app:tint="@color/blanco" />

    </LinearLayout>
</ScrollView>
