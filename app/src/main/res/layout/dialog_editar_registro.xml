<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@android:color/transparent">

    <TextView
        android:id="@+id/tvTituloDialog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Editar Serie"
        android:textColor="@color/blanco"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="20dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Repeticiones -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="10dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reps"
                android:textColor="@color/blanco"
                android:textSize="12sp" />
            <NumberPicker
                android:id="@+id/npRepeticionesEdit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:theme="@style/PickerStyle" />
        </LinearLayout>

        <!-- Peso Entero -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kg"
                android:textColor="@color/blanco"
                android:textSize="12sp" />
            <NumberPicker
                android:id="@+id/npPesoEnteroEdit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:theme="@style/PickerStyle" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="."
            android:textColor="@color/blanco"
            android:textSize="30sp"
            android:layout_marginTop="20dp"/>

        <!-- Peso Decimal -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="g"
                android:textColor="@color/blanco"
                android:textSize="12sp" />
            <NumberPicker
                android:id="@+id/npPesoDecimalEdit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:theme="@style/PickerStyle" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="20dp">

        <Button
            android:id="@+id/btnCancelarEdit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CANCELAR"
            android:textColor="@color/blanco"
            android:backgroundTint="#403C3C"
            android:layout_marginEnd="12dp"
            android:textSize="14sp"
            android:paddingHorizontal="20dp"
            android:paddingVertical="8dp"
            android:minHeight="0dp"
            android:minWidth="0dp"
            app:cornerRadius="20dp"
            style="@style/Widget.Material3.Button.TonalButton"/>

        <Button
            android:id="@+id/btnAceptarEdit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACEPTAR"
            android:textColor="@color/blanco"
            android:backgroundTint="#403C3C"
            android:textSize="14sp"
            android:paddingHorizontal="20dp"
            android:paddingVertical="8dp"
            android:minHeight="0dp"
            android:minWidth="0dp"
            app:cornerRadius="20dp"
            style="@style/Widget.Material3.Button.TonalButton"/>
    </LinearLayout>
</LinearLayout>
